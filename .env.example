# ─────────────────────────────────────────────────────────
# WMKB Frontend — Environment Configuration
# Copy this to .env and customize as needed
# ─────────────────────────────────────────────────────────

# Host port the public site is exposed on (default: 5070)
WMKB_PORT=5070

# Secret key for session encryption (leave blank to auto-generate + persist
# to /data/.secret_key). Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 when served over HTTPS (behind your reverse proxy) so session
# cookies get the Secure flag and HSTS is sent.
WMKB_SECURE_COOKIES=
